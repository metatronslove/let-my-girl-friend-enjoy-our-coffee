msgid "Tip:"
msgstr "ຕົວແທນ:"

msgid ""
"If you are outside the US, we recommend NOWPayments (lowest fees, direct to "
"your wallet). If you are in the US, Stripe Crypto is also an option. You can"
" enable multiple services and let your visitors choose!"
msgstr ""
"ຖ້າທ່ານຢູ່ນอก US, ພວກເຮົາແນະນຳ NOWPayments (ຄ່າເງິນສະເຫຼີມ, ສົ່ງໜ້າທ່ານໄປ). "
"ຖ້າທ່ານຢູ່ພາຍໃນ US, Stripe Crypto ແມ່ນຕົວເລືອກອື່ນ. "
"ທ່ານສາມາດເປີດຕັ້ງບໍລິການທີ່ຫຼາຍແລະເຮັດໃຫ້ເຂົ້າເສີມເລືອກ!"

msgid "Enabled Payment Methods"
msgstr "ວິທີຈ່າຍແປກທີ່ເປີດ"

msgid ""
"Select which payment options will appear in your widget. Your visitors can "
"choose their preferred method."
msgstr ""
"ເລືອກວິທີຈ່າຍທີ່ຈະສະເໝນໃນ widget ຂອງທ່ານ. ເຂົ້າເສີມແລະເລືອກເວລາຂອງທ່ານ."

msgid "Show these methods"
msgstr "ສະເໝນວິທີນີ້"

msgid "🔗 Direct Crypto (Wallet address)"
msgstr "🔗 Direct Crypto (ທີ່ເປັນບັນທຸກ)"

msgid "⚡ NOWPayments (Credit Card → Crypto)"
msgstr "⚡ NOWPayments (ໜີ້ຄອດ → Crypto)"

msgid "🪙 CoinGate (Credit Card → Crypto)"
msgstr "🪙 CoinGate (ໜີ້ຄອດ → Crypto)"

msgid "🏦 BitPay (Credit Card → Crypto)"
msgstr "🏦 BitPay (ໜີ້ຄອດ → Crypto)"

msgid "🌙 MoonPay (User buys crypto first)"
msgstr "🌙 MoonPay (ຜູ້ໃຊ້ຂອງທ່ານຊື້ Crypto ກ່ອນ)"

msgid "💳 Stripe (Credit Card)"
msgstr "💳 Stripe (ໜີ້ຄອດ)"

msgid "🟡 PayPal"
msgstr "🟡 PayPal"

msgid ""
"Display your wallet address so users can send crypto directly. Zero fees, "
"but requires users to already have crypto."
msgstr ""
"ສະເໝນທີ່ເປັນບັນທຸກເປັນເກັບໃສ່ຜູ້ໃຊ້ເພື່ອສົ່ງ crypto ເປັນຕອນແລ່ນ. "
"ບໍ່ມີຄ່າເງິນ, ແຕ່ຕ້ອງການຜູ້ໃຊ້ມີ crypto ແລ້ວ."

msgid "Wallet Address"
msgstr "ທີ່ເປັນບັນທຸກ"

msgid "Your Quai, Ethereum, Bitcoin, or other wallet address."
msgstr "ທີ່ເປັນບັນທຸກ Quai, Ethereum, Bitcoin ຫຼືທີ່ເປັນບັນທຸກອື່ນໆ."

msgid "Network"
msgstr "ໜ່າງ"

msgid "Quai Network (Recommended - free)"
msgstr "ໜ່າງ Quai (ແນະນຳ - ຟຣີ)"

msgid "Ethereum"
msgstr "Ethereum"

msgid "Bitcoin"
msgstr "Bitcoin"

msgid "Solana"
msgstr "Solana"

msgid "Polygon"
msgstr "Polygon"

msgid "Best for beginners & lowest fees"
msgstr "ເປັນຜູ້ເລີ່ມຕົ້ນທີ່ດີ & ຄ່າຈ່າຍທີ່ລົດ"

msgid ""
"NOWPayments allows you to accept credit card payments directly to your "
"crypto wallet. Funds go straight to your wallet – no middleman."
msgstr ""
"NOWPayments "
"ອະນຸຍົມໃຫ້ທ່ານຮັບການຈ່າຍເງິນຕ່າງໆໃນເບັກຄຣີບໂຕມັນຂອງທ່ານເວັ້ນຜ່ານເປັນບ່ອນເງິນ"
" – ບໍ່ມີຜູ່ລວມ"

msgid "Fee:"
msgstr "ຄ່າຈ່າຍ:"

msgid "per transaction"
msgstr "ໂດຍທຸກຕໍ່"

msgid "Payout:"
msgstr "ຈ່າຍແກ່:"

msgid "Direct to your wallet"
msgstr "ແທນເບັກ"

msgid "Setup:"
msgstr "ຕັ້ງແຕ່ນ"

msgid "Create free account → API Keys → Copy API Key"
msgstr "ສ້າງບັນຊີຟຣີ → ລະຫັດ API → ສະຫລຸນໃສ່ລະຫັດ API"

msgid "NOWPayments API Key"
msgstr "ລະຫັດ API NOWPayments"

msgid "Paste your API key from NOWPayments dashboard."
msgstr "ຂຽນລະຫັດ API ຂອງທ່ານຈາກໜ່ວຍຂໍ້ມູນ NOWPayments"

msgid "Great support, slightly higher fee"
msgstr "ການສະໜອງທີ່ດີ, ຄ່າຈ່າຍເກີນເຕັ້ນ"

msgid ""
"CoinGate is a well-established crypto payment processor with an official "
"WordPress plugin."
msgstr "CoinGate ແມ່ນຜະລິດການເງິນຄຣີບໂຕມັນທີ່ມີຄວາມສະເພາະກັບເຜົາ WordPress"

msgid "1% per transaction"
msgstr "1% ໂດຍທຸກຕໍ່"

msgid "coingate.com"
msgstr "coingate.com"

msgid "Create account → API Keys"
msgstr "ສ້າງບັນຊີ → ລະຫັດ API"

msgid "CoinGate API Key"
msgstr "ລະຫັດ API CoinGate"

msgid "Enterprise-grade, US-friendly"
msgstr "ລະດັບຕົນລາງ, ມີພາບທຸລະກິດ US"

msgid ""
"BitPay is trusted by major companies. Works well for US-based businesses."
msgstr "BitPay ຕອບເທັນໃນອຸດສາຫະນະມາເຈັນ, ປະເທດ US ຂຽນເວັ່ນເປັນຂອງທ່ານ"

msgid "bitpay.com"
msgstr "bitpay.com"

msgid "Business account → API Keys"
msgstr "ບັນຊີທຸລະກິດ → ລະຫັດ API"

msgid "BitPay API Key"
msgstr "ລະຫັດ API BitPay"

msgid "Users buy crypto first, then send to you"
msgstr "ຜູ້ໃຊ້ຊື້ crypto ແລ້ວສົ່ງໃຫ່ກັນ"

msgid ""
"MoonPay lets users buy crypto with credit card directly to THEIR wallet, "
"then they send it to you. Higher fees but very simple for users."
msgstr ""
"MoonPay ສ່ວນງານຜູ້ໃຊ້ໃຫ້ຊື້ crypto ເພື່ອເປັນເບັກຂອງພວກເຂົ້າ, "
"ແລະພວກເຂົ້າສົ່ງໃຫ່ກັນ. ຄ່າຈ່າຍເກີນເຕັ້ນ ແຕ່ງ່າຍໃນການໃຊ້"

msgid "~3.5% per transaction"
msgstr "~3.5% ໂດຍທຸກຕໍ່"

msgid "User's wallet first"
msgstr "ເບັກຂອງຜູ້ໃຊ້ແກ່"

msgid "moonpay.com"
msgstr "moonpay.com"

msgid "MoonPay API Key"
msgstr "ລະຫັດ API MoonPay"

msgid "Stripe"
msgstr "Stripe"

msgid "Important:"
msgstr "ສຳຄັນ:"

msgid ""
"Stripe Crypto payments (USDC) are ONLY available for US-based businesses. If"
" you are outside the US, Stripe will only accept credit card payments to "
"your Stripe balance (not directly to crypto)."
msgstr ""
"ຈ່າຍເງິນ Crypto ຂອງ Stripe (USDC) "
"ເປັນເປັນສ່ວນຕ່າງການຕິດຕໍ່ກັບບໍລິສັດທີ່ຢູ່ໃນສະຫະນິບອາເມລີ. "
"ຖ້າທ່ານຢູ່ອນອະນາຄົ້ນສະຫະນິບອາເມລີ, Stripe "
"ຈະເປັນໃນການຈ່າຍເງິນໂດຍບັດຄັດເຂົ້າເຖິງບັນຊີ Stripe ຂອງທ່ານ (ບໍ່ເປັນ Crypto)."

msgid ""
"If you are in the US, you can use Stripe to receive crypto directly. If "
"outside, consider NOWPayments or CoinGate for direct crypto payouts."
msgstr ""
"ຖ້າທ່ານຢູ່ສະຫະນິບອາເມລີ, ທ່ານສາມາດໃຊ້ Stripe เพื่อรับ Crypto ตรง ๆ. "
"ຖ້າຢູ່ອນອະນາຄົ້ນ, ເລືອກ NOWPayments ຫຼື CoinGate ເພື່ອສົ່ງ Crypto ตรง ๆ."

msgid "Stripe Publishable Key"
msgstr "ລະຫັດຈັດພິສ່ມໃຫ້ Stripe"

msgid "Stripe Secret Key"
msgstr "ລະຫັດໝັ້ນທ່ານ Stripe"

msgid ""
"Classic PayPal payments. Users pay with PayPal balance or credit card. Funds"
" go to your PayPal account."
msgstr ""
"ຈ່າຍເງິນ PayPal ເທົ່າເທົ່າ. ຜູ້ໃຊ້ຈ່າຍໂດຍມັນ PayPal ຫຼືບັດຄັດ. "
"ຈ່າຍເງິນຈະເຂົ້າໃນບັນຊີ PayPal ຂອງທ່ານ."

msgid "Standard PayPal transaction fees apply."
msgstr "ຄ່າທຶນການປ່ອງຂອງ PayPal ແມ່ນ Standard."

msgid "PayPal Client ID"
msgstr "ລະຫັດລູກຄ້າ PayPal"

msgid ""
"Get your PayPal API credentials from <a "
"href=\"https://developer.paypal.com/\" target=\"_blank\">PayPal Developer "
"Dashboard</a>."
msgstr ""
"ດຶອນຂໍ້ມູນ API PayPal ຂອງທ່ານຈາກ <a href=\"https://developer.paypal.com/\" "
"target=\"_blank\">PayPal Developer Dashboard</a>."

msgid "PayPal Secret"
msgstr "ລະຫັດໝັ້ນ PayPal"

msgid "Donation Tiers"
msgstr "ຈັດກະເລີນການລາຍງຽນ"

msgid "Add Tier"
msgstr "ເພີ່ມຂໍ້ມູນ"

msgid "Remove"
msgstr "ລຶບ"

msgid "Predefined donation amounts (USD). Leave empty for custom amount only."
msgstr ""
"ຈ່າຍເງິນທີ່ບອກເວົ້າ (USD). ຢ່າງງ່າຍທີ່ດັ່ງກ່ອນກະທັບໃນການລະອົງຄ່າຕົວເລີ່ມ."

