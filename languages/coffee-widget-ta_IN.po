msgstr "உறுப்பினரை இயலுமைப்படுத்து"

msgid "Allow recurring subscriptions (requires Stripe Subscriptions)."
msgstr "மறுமுறை சந்தாக்களை அனுமதி (Stripe Subscriptions தேவை)."

msgid "Support"
msgstr "ஆதரவு"

msgid "Donate"
msgstr "நன்கொடை"

msgid "Crypto"
msgstr "கிரிப்டோ"

msgid "Credit Card"
msgstr "கிரெடிட் கார்டு"

msgid "Choose amount"
msgstr "தொகை தேர்வு"

msgid "Custom amount"
msgstr "தனிப்பயன் தொகை"

msgid "Enter amount (USD)"
